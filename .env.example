# Get a key at https://developer.riotgames.com/ — dev keys expire every 24h
RIOT_API_KEY=RGAPI-your-key-here

# Regional route: americas (NA/BR/LAN/LAS) | europe (EUW/EUNE) | asia (KR/JP) | sea
RIOT_REGIONAL_ROUTE=americas
# Platform route: na1 | euw1 | eun1 | kr | br1 | la1 | la2 | oc1 | tr1 | jp1
RIOT_PLATFORM_ROUTE=na1

# Your PUUID — look it up once via _api.lookup_puuid("GameName", "TAG") and paste here
LOL_MATCH_AI_MY_PUUID=your-puuid-here
